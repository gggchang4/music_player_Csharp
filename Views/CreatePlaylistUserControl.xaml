<UserControl x:Class="MusicPlayerApp.Views.CreatePlaylistUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicPlayerApp.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 标题和工具栏 -->
        <Grid Grid.Row="0" Margin="20,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="创建新播放列表" Style="{DynamicResource TitleTextStyle}" VerticalAlignment="Center"/>
        </Grid>
        
        <!-- 内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="500" HorizontalAlignment="Left" Margin="20,10,20,20">
                <materialDesign:Card Margin="0,0,0,20" Padding="20">
                    <StackPanel>
                        <!-- 播放列表基本信息 -->
                        <TextBlock Text="播放列表信息" 
                                   FontWeight="SemiBold" 
                                   FontSize="16" 
                                   Margin="0,0,0,15"/>
                        
                        <!-- 播放列表名称 -->
                        <TextBox materialDesign:HintAssist.Hint="播放列表名称"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding PlaylistName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,15"/>
                        
                        <!-- 播放列表描述 -->
                        <TextBox materialDesign:HintAssist.Hint="描述（选填）"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding PlaylistDescription, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Height="100"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,15"/>
                        
                        <!-- 播放列表标签 -->
                        <TextBox materialDesign:HintAssist.Hint="标签（选填，多个标签用空格分隔）"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding PlaylistTags, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,15"/>
                        
                        <!-- 创建按钮 -->
                        <Button Content="创建播放列表"
                                Command="{Binding CreatePlaylistCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl> 