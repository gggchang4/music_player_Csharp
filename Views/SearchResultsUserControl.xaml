<UserControl x:Class="MusicPlayerApp.Views.SearchResultsUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicPlayerApp.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:MusicPlayerApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToObjectConverter x:Key="BoolToFavoriteIconConverter" 
                                         TrueValue="Favorite" 
                                         FalseValue="FavoriteBorder" />
        <converters:BoolToObjectConverter x:Key="BoolToFavoriteColorConverter" 
                                         TrueValue="#FF5252" 
                                         FalseValue="#AAAAAA" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,10,20,0">
            <Button 
                Command="{Binding BackCommand}" 
                Style="{DynamicResource MaterialDesignFlatButton}" 
                ToolTip="返回" 
                Margin="0,0,10,0">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24"/>
            </Button>
            <TextBlock Text="搜索结果:" FontSize="20" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SearchQuery}" FontSize="20" FontStyle="Italic" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 搜索框 -->
        <Grid Grid.Row="1" Margin="20,10,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBox Grid.Column="0" 
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,10,0"
                     materialDesign:HintAssist.Hint="搜索音乐、艺术家或专辑..."
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     KeyDown="SearchTextBox_KeyDown"/>
            
            <Button Grid.Column="1" 
                    Command="{Binding SearchCommand}"
                    Style="{DynamicResource MaterialDesignRaisedButton}"
                    Background="{DynamicResource PrimaryHueMidBrush}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Magnify" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="搜索"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 搜索结果 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 加载指示器 -->
                <ProgressBar Grid.Row="0" Grid.RowSpan="3"
                            IsIndeterminate="True"
                            Margin="0,100,0,0"
                            HorizontalAlignment="Center"
                            Width="60" Height="60"
                            Style="{DynamicResource MaterialDesignCircularProgressBar}"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- 艺术家结果 -->
                <StackPanel Grid.Row="0" Margin="20,0,20,20"
                          Visibility="{Binding Artists.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="艺术家" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding Artists}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <materialDesign:PackIcon Kind="Account" 
                                                           Grid.Column="0"
                                                           Width="32" Height="32" 
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" 
                                          Style="{DynamicResource MaterialDesignFlatButton}"
                                          Command="{Binding DataContext.NavigateToArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="ArrowRightBold" Width="24" Height="24"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Separator Margin="0,10,0,0"/>
                </StackPanel>

                <!-- 专辑结果 -->
                <StackPanel Grid.Row="1" Margin="20,0,20,20"
                          Visibility="{Binding Albums.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="专辑" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding Albums}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <materialDesign:PackIcon Kind="Album" 
                                                           Grid.Column="0"
                                                           Width="32" Height="32" 
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Artist.Name}" FontSize="12" Opacity="0.7"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" 
                                          Style="{DynamicResource MaterialDesignFlatButton}"
                                          Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="ArrowRightBold" Width="24" Height="24"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Separator Margin="0,10,0,0"/>
                </StackPanel>

                <!-- 歌曲结果 -->
                <StackPanel Grid.Row="2" Margin="20,0,20,20"
                          Visibility="{Binding Songs.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="歌曲" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ListView ItemsSource="{Binding Songs}" 
                            BorderThickness="0"
                            Style="{DynamicResource MaterialDesignListView}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Artist.Name}" FontSize="12" Opacity="0.7"/>
                                            <TextBlock Text=" - " FontSize="12" Opacity="0.7"/>
                                            <TextBlock Text="{Binding Album.Title}" FontSize="12" Opacity="0.7"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 收藏按钮 -->
                                    <Button Grid.Column="1" 
                                          Style="{DynamicResource MaterialDesignFlatButton}"
                                          Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="FavoriteBorder" Width="24" Height="24"/>
                                    </Button>

                                    <!-- 添加到播放列表按钮 -->
                                    <Button Grid.Column="2" 
                                          Style="{DynamicResource MaterialDesignFlatButton}"
                                          Command="{Binding DataContext.AddToPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="PlaylistPlus" Width="24" Height="24"/>
                                    </Button>

                                    <!-- 播放按钮 -->
                                    <Button Grid.Column="3" 
                                          Style="{DynamicResource MaterialDesignFlatButton}"
                                          Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Play" Width="24" Height="24"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- 无搜索结果提示 -->
                <TextBlock Grid.Row="0"
                         Text="没有找到匹配的结果"
                         FontSize="16"
                         HorizontalAlignment="Center"
                         Margin="0,50,0,0"
                         Visibility="{Binding HasNoResults, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl> 