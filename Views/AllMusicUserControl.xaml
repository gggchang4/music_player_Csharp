<UserControl x:Class="MusicPlayerApp.Views.AllMusicUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicPlayerApp.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:MusicPlayerApp.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题和工具栏 -->
        <Grid Grid.Row="0" Margin="20,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="所有音乐" Style="{DynamicResource TitleTextStyle}" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Style="{DynamicResource MaterialDesignIconButton}" 
                        ToolTip="刷新" Margin="5,0"
                        Command="{Binding RefreshCommand}">
                    <materialDesign:PackIcon Kind="Refresh" Width="22" Height="22"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Background="{DynamicResource ContentBackground}">
            <!-- 加载指示器 -->
            <materialDesign:Card Padding="30" 
                                 VerticalAlignment="Center" HorizontalAlignment="Center"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <ProgressBar Style="{DynamicResource MaterialDesignCircularProgressBar}" 
                                 Value="0" IsIndeterminate="True" 
                                 Width="50" Height="50" Margin="0,0,0,15"/>
                    <TextBlock Text="正在加载音乐库..." HorizontalAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- 无歌曲显示 - 放在最下层 -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" x:Name="EmptyLibraryMessage" Panel.ZIndex="1">
                <TextBlock Text="音乐库为空" 
                           FontSize="18" FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBody}"/>
                <TextBlock Text="点击导入音乐按钮添加歌曲" 
                           Margin="0,10,0,15"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBody}"/>
            </StackPanel>

            <!-- 歌曲列表 - 放在最上层 -->
            <DataGrid x:Name="SongsDataGrid" 
                      Panel.ZIndex="2"
                      ItemsSource="{Binding Songs}" 
                      SelectedItem="{Binding SelectedSong}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      Background="Transparent"
                      BorderThickness="0"
                      RowHeaderWidth="0"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      Margin="10,0,10,10"
                      Foreground="{DynamicResource MaterialDesignBody}"
                      ColumnWidth="SizeToHeader"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                      RowHeight="40">
                
                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#4C6EF5"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
                </DataGrid.Resources>
                
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Height" Value="40"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#4C6EF5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="VerticalAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="8,4"/>
                    </Style>
                </DataGrid.CellStyle>
                
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="45">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource MaterialDesignIconButton}" 
                                        Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Foreground="{DynamicResource MaterialDesignPaper}"
                                        Width="28" Height="28"
                                        Padding="0"
                                        Background="{DynamicResource PrimaryHueMidBrush}"
                                        BorderBrush="Transparent"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Play" Width="12" Height="12"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="2*" MinWidth="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding Title}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="艺术家" Binding="{Binding Artist.Name}" Width="*" MinWidth="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding Artist.Name}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="专辑" Binding="{Binding Album.Title}" Width="*" MinWidth="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding Album.Title}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="时长" Binding="{Binding Duration, Converter={StaticResource SecondsToTimeStringConverter}}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,10,0"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Width="45">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource MaterialDesignIconButton}" 
                                        Command="{Binding DataContext.AddToPlaylistCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Foreground="{DynamicResource MaterialDesignPaper}"
                                        Width="28" Height="28"
                                        Padding="0"
                                        Background="{DynamicResource PrimaryHueMidBrush}"
                                        BorderBrush="Transparent"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="PlaylistPlus" Width="12" Height="12"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <!-- 喜欢按钮 -->
                    <DataGridTemplateColumn Width="45">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="FavoriteButton"
                                        Style="{StaticResource MaterialDesignIconButton}" 
                                        Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Foreground="{DynamicResource MaterialDesignPaper}"
                                        Width="28" Height="28"
                                        Padding="0"
                                        Background="{DynamicResource PrimaryHueMidBrush}"
                                        BorderBrush="Transparent"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Click="FavoriteButton_Click"
                                        ToolTip="添加到我喜欢的音乐">
                                    <materialDesign:PackIcon Kind="Heart" Width="12" Height="12"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>

                <!-- 右键菜单 -->
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="播放" 
                                  Command="{Binding Path=PlacementTarget.DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                  CommandParameter="{Binding Path=PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="Play" Width="18" Height="18"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="添加到播放列表" 
                                  Command="{Binding Path=PlacementTarget.DataContext.AddToPlaylistCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                  CommandParameter="{Binding Path=PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="PlaylistPlus" Width="18" Height="18"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="添加到我喜欢的音乐" 
                                  Command="{Binding Path=PlacementTarget.DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                  CommandParameter="{Binding Path=PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="Heart" Width="18" Height="18"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>