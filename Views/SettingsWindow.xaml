<Window x:Class="MusicPlayerApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicPlayerApp.Views"
        xmlns:viewmodels="clr-namespace:MusicPlayerApp.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="设置" 
        Height="500" Width="600" 
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="设置" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Margin="0,0,0,10"/>
            <TextBlock Text="自定义您的音乐播放器体验" Style="{StaticResource MaterialDesignBody1TextBlock}" Opacity="0.7"/>
        </StackPanel>

        <!-- 主内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 一般设置 -->
                <Expander Header="一般设置" IsExpanded="True" Margin="0,0,0,10"
                          BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MaterialDesignDivider}">
                    <StackPanel Margin="10">
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="默认音量" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Width="200" Minimum="0" Maximum="100" Value="{Binding DefaultVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>
                </Expander>
                
                <!-- 显示设置 -->
                <Expander Header="显示设置" IsExpanded="True" Margin="0,0,0,10"
                          BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MaterialDesignDivider}">
                    <StackPanel Margin="10">
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="主题" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" Width="100" 
                                      SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="深色"/>
                                <ComboBoxItem Content="浅色"/>
                                <ComboBoxItem Content="跟随系统"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Expander>
                
                <!-- 数据设置 -->
                <Expander Header="数据设置" Margin="0,0,0,10"
                          BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MaterialDesignDivider}">
                    <StackPanel Margin="10">
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="音乐库位置" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="200" Text="{Binding MusicLibraryPath, Mode=TwoWay}" IsReadOnly="True"/>
                                <Button Content="浏览" 
                                        Style="{StaticResource MaterialDesignOutlinedButton}" 
                                        Margin="5,0,0,0" 
                                        Command="{Binding BrowseMusicFolderCommand}"/>
                            </StackPanel>
                        </Grid>
                        
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="缓存大小" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="100" Text="{Binding CacheSize, Mode=TwoWay}"/>
                                <TextBlock Text="MB" Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        
                        <Button Content="清除缓存" 
                                Style="{StaticResource MaterialDesignOutlinedButton}" 
                                HorizontalAlignment="Left" Margin="0,10,0,0"
                                Command="{Binding ClearCacheCommand}"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" 
                    Content="重置" Margin="0,0,10,0" 
                    Command="{Binding ResetCommand}"/>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" 
                    Content="应用" Margin="0,0,10,0" 
                    Command="{Binding ApplyCommand}"/>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" 
                    Content="取消" Margin="0,0,10,0" 
                    Command="{Binding CancelCommand}"
                    Click="CancelButton_Click"/>
            <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                    Content="保存" 
                    Command="{Binding SaveCommand}"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window> 