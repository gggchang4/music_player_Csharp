<Window x:Class="MusicPlayerApp.Views.UserProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicPlayerApp.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="用户资料" 
        Height="550" Width="600" 
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="AvatarButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Width" Value="40"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="5,0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <materialDesign:Card Margin="10" VerticalAlignment="Stretch">
            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="用户资料" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Margin="0,0,0,10"
                           FontWeight="Bold"/>
                    <TextBlock Text="个性化您的账户信息和偏好设置" Style="{StaticResource MaterialDesignBody1TextBlock}" Opacity="0.7"/>
                    <Separator Margin="0,15,0,0"/>
                </StackPanel>

                <!-- 主内容 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 用户头像和基本信息 -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,10,0,30">
                            <Border Width="120" Height="120" Background="{DynamicResource PrimaryHueMidBrush}" 
                                CornerRadius="60" Margin="0,0,0,15">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3" />
                                </Border.Effect>
                                <TextBlock Text="用户" FontSize="42" HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}" FontWeight="Medium"/>
                            </Border>
                            
                            <Button Content="更换头像" Style="{StaticResource MaterialDesignFlatButton}" 
                                x:Name="ChangeAvatarButton"
                                HorizontalAlignment="Center" Margin="0,0,0,10"
                                Click="ChangeAvatarButton_Click" />
                            
                            <TextBlock Text="当前用户" HorizontalAlignment="Center" FontSize="18" FontWeight="Medium"/>
                        </StackPanel>
                        
                        <!-- 用户详细信息 -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 用户名 -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,20" Orientation="Vertical">
                                <TextBlock Text="用户名" VerticalAlignment="Center" FontWeight="Medium"/>
                                <TextBlock Text="您的登录标识" FontSize="11" Opacity="0.6"/>
                            </StackPanel>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="默认用户" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                 Margin="0,0,0,20"/>
                            
                            <!-- 电子邮件 -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,20" Orientation="Vertical">
                                <TextBlock Text="电子邮件" VerticalAlignment="Center" FontWeight="Medium"/>
                                <TextBlock Text="用于接收通知" FontSize="11" Opacity="0.6"/>
                            </StackPanel>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="user@example.com" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                 Margin="0,0,0,20"/>
                            
                            <!-- 个人简介 -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,5,10,20" Orientation="Vertical">
                                <TextBlock Text="个人简介" VerticalAlignment="Top" FontWeight="Medium"/>
                                <TextBlock Text="关于您的音乐品味" FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBox Grid.Row="2" Grid.Column="1"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 Height="100" Margin="0,0,0,20"
                                 Text="这里是我的个人音乐简介。我喜欢各种类型的音乐，特别是流行和摇滚。"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- 底部按钮 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" HorizontalAlignment="Left"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Content="删除账户" Foreground="#D32F2F"
                        Margin="0,15,0,0"/>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}" 
                            Content="取消" Margin="0,0,10,0" 
                            Click="CancelButton_Click"/>
                        <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                            Content="保存" 
                            Click="SaveButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>
        
        <!-- 头像选择对话框 -->
        <materialDesign:DialogHost x:Name="AvatarDialogHost" IsOpen="False">
            <materialDesign:DialogHost.DialogContent>
                <Border Width="400" Background="{DynamicResource MaterialDesignPaper}" Padding="20">
                    <StackPanel>
                        <TextBlock Text="选择头像" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,20"/>
                        <WrapPanel HorizontalAlignment="Center" Margin="0,10">
                            <!-- 预设头像选项 -->
                            <Button Style="{StaticResource AvatarButtonStyle}" Background="#7B1FA2" 
                                    Click="AvatarButton_Click">
                                <TextBlock Text="用" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource AvatarButtonStyle}" Background="#D32F2F" 
                                    Click="AvatarButton_Click">
                                <TextBlock Text="音" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource AvatarButtonStyle}" Background="#1976D2" 
                                    Click="AvatarButton_Click">
                                <TextBlock Text="乐" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource AvatarButtonStyle}" Background="#388E3C" 
                                    Click="AvatarButton_Click">
                                <TextBlock Text="享" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource AvatarButtonStyle}" Background="#F57C00" 
                                    Click="AvatarButton_Click">
                                <TextBlock Text="听" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}" FontWeight="Bold"/>
                            </Button>
                        </WrapPanel>
                        
                        <Separator Margin="0,10"/>
                        
                        <TextBlock Text="自定义头像" Margin="0,10,0,5"/>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="选择图片文件..." 
                                HorizontalAlignment="Left" Margin="0,5,0,20"
                                Click="SelectImageButton_Click"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    Content="取消"
                                    Click="CloseAvatarDialog" Margin="0,0,8,0"/>
                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                    Content="确定"
                                    Click="CloseAvatarDialog"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>
    </Grid>
</Window> 