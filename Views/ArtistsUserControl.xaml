<UserControl x:Class="MusicPlayerApp.Views.ArtistsUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicPlayerApp.Views"
             xmlns:viewmodels="clr-namespace:MusicPlayerApp.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:MusicPlayerApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    

    <Grid Background="{DynamicResource ContentBackground}">
        <Grid.Resources>
            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
            </Style>
        </Grid.Resources>
        
        <!-- 显示艺术家列表或艺术家详情 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 艺术家列表 -->
            <Grid Visibility="{Binding IsArtistDetailVisible, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 标题栏 -->
                <Grid Grid.Row="0" Margin="15,15,15,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="艺术家" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource MaterialDesignBody}"/>
                    
                    <Button Grid.Column="1" Command="{Binding RefreshCommand}" ToolTip="刷新列表">
                        <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20"/>
                    </Button>
                </Grid>
                
                <!-- 艺术家列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="15,5,15,15">
                    <!-- 使用WrapPanel展示艺术家，类似网格布局 -->
                    <ItemsControl ItemsSource="{Binding Artists}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="150" Height="180" Margin="10" 
                                        Command="{Binding DataContext.SelectArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}">
                                    <StackPanel HorizontalAlignment="Center" Width="120">
                                        <!-- 艺术家图像 -->
                                        <Border Width="100" Height="100" CornerRadius="50" Background="#333333"
                                                BorderThickness="1" BorderBrush="#444444" HorizontalAlignment="Center">
                                            <Grid>
                                                <Image Source="{Binding Image}" Stretch="Uniform">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Image}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <materialDesign:PackIcon Kind="Account" Width="50" Height="50" 
                                                                         HorizontalAlignment="Center" 
                                                                         VerticalAlignment="Center" 
                                                                         Foreground="{DynamicResource MaterialDesignBody}">
                                                    <materialDesign:PackIcon.Style>
                                                        <Style TargetType="materialDesign:PackIcon">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Image}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </materialDesign:PackIcon.Style>
                                                </materialDesign:PackIcon>
                                            </Grid>
                                        </Border>
                                        
                                        <!-- 艺术家名称 -->
                                        <TextBlock Text="{Binding Name}" Margin="0,10,0,0" 
                                                   TextWrapping="Wrap" TextAlignment="Center" 
                                                   HorizontalAlignment="Center"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesignBody}"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <!-- 加载指示器 -->
                <Grid Grid.Row="1" Background="#99000000" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" 
                                 Value="0" IsIndeterminate="True" 
                                 Width="50" Height="50" />
                </Grid>
            </Grid>
            
            <!-- 艺术家详情 -->
            <Grid Visibility="{Binding IsArtistDetailVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 返回按钮 -->
                <Button Grid.Row="0" HorizontalAlignment="Left" Margin="15,15,0,0"
                        Command="{Binding BackToArtistsCommand}" 
                        Style="{StaticResource MaterialDesignIconButton}">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24"/>
                </Button>
                
                <!-- 艺术家信息 -->
                <Grid Grid.Row="1" Margin="15,10,15,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 艺术家图像 -->
                    <Border Grid.Column="0" Width="150" Height="150" CornerRadius="75"
                            Background="#333333" BorderThickness="1" BorderBrush="#444444"
                            Margin="0,0,20,0">
                        <Grid>
                            <Image Source="{Binding SelectedArtist.Image}" Stretch="Uniform">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedArtist.Image}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <materialDesign:PackIcon Kind="Account" Width="50" Height="50" 
                                                     HorizontalAlignment="Center" 
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource MaterialDesignBody}">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedArtist.Image}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                        </Grid>
                    </Border>
                    
                    <!-- 艺术家信息 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedArtist.Name}" FontSize="28" 
                                   FontWeight="Bold" Foreground="{DynamicResource MaterialDesignBody}" TextWrapping="Wrap"/>
                        
                        <!-- 使用单一TextBlock来显示歌曲数量 -->
                        <TextBlock Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,10,0,0">
                            <TextBlock.Text>
                                <Binding Path="ArtistSongs.Count" Converter="{StaticResource SongCountConverter}" />
                            </TextBlock.Text>
                        </TextBlock>
                        
                        <Button Content="播放全部" Margin="0,15,0,0" 
                                Command="{Binding PlayAllSongsCommand}" 
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{DynamicResource PrimaryHueMidBrush}"/>
                    </StackPanel>
                </Grid>
                
                <!-- 歌曲列表 -->
                <DataGrid Grid.Row="2" ItemsSource="{Binding ArtistSongs}" 
                          AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionMode="Single" GridLinesVisibility="None"
                          Background="Transparent" BorderThickness="0"
                          RowHeight="45" AlternationCount="10000">
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#4C6EF5"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
                        
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            <Setter Property="Padding" Value="10,5"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                    </DataGrid.Resources>
                    
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Height" Value="45"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#4C6EF5"/>
                                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3FFFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="VerticalAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8,4"/>
                        </Style>
                    </DataGrid.CellStyle>
                    
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Foreground="{DynamicResource MaterialDesignPaper}"
                                            Width="30" Height="30"
                                            Padding="0"
                                            Background="#7B1FA2"
                                            BorderBrush="Transparent"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Play" Width="14" Height="14"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="序号" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding 
                                                Path=AlternationIndex, 
                                                RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, 
                                                StringFormat={}{0:D}}" 
                                             Foreground="{DynamicResource MaterialDesignBody}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Padding="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="歌曲标题" Binding="{Binding Title}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="ToolTip" Value="{Binding Title}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="专辑" Binding="{Binding Album.Title}" Width="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="ToolTip" Value="{Binding Album.Title}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="时长" Binding="{Binding Duration, Converter={StaticResource SecondsToTimeStringConverter}}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                    <Setter Property="Padding" Value="5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
                
                <!-- 加载指示器 -->
                <Grid Grid.Row="2" Background="#99000000" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" 
                                 Value="0" IsIndeterminate="True" 
                                 Width="50" Height="50" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl> 