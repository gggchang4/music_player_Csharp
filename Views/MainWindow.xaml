<Window x:Class="MusicPlayerApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicPlayerApp.Views"
        xmlns:UserControls="clr-namespace:MusicPlayerApp.UserControls"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewModels="clr-namespace:MusicPlayerApp.ViewModels"
        xmlns:converters="clr-namespace:MusicPlayerApp.Converters"
        xmlns:controls="clr-namespace:MusicPlayerApp.Controls"
        mc:Ignorable="d"
        Title="音乐播放器" Height="700" Width="1200" 
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{materialDesign:MaterialDesignFont}">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 顶部栏 -->
            <RowDefinition Height="*"/>
            <!-- 主内容区 -->
            <RowDefinition Height="Auto"/>
            <!-- 播放控制栏 -->
        </Grid.RowDefinitions>

        <!-- 顶部栏 -->
        <Grid Grid.Row="0" Background="{DynamicResource TopBarBackground}" Height="60">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧Logo -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                <materialDesign:PackIcon Kind="MusicCircle" Width="30" Height="30" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="音乐播放器" FontSize="20" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBody}"/>
            </StackPanel>

            <!-- 搜索框 -->
            <Grid Grid.Column="1" Margin="20,0">
                <TextBox Width="400" HorizontalAlignment="Left" VerticalAlignment="Center"
                         materialDesign:HintAssist.Hint="搜索音乐、艺术家或专辑..."
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource MaterialDesignOutlinedTextBox}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}" CommandParameter="{Binding SearchQuery}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button HorizontalAlignment="Left" Margin="410,0,0,0" VerticalAlignment="Center"
                        Style="{DynamicResource MaterialDesignIconButton}"
                        Command="{Binding SearchCommand}" 
                        CommandParameter="{Binding SearchQuery}">
                    <materialDesign:PackIcon Kind="Magnify" Width="24" Height="24"/>
                </Button>
            </Grid>

            <!-- 用户信息和设置 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="15,0">
                <Button Style="{DynamicResource MaterialDesignIconForegroundButton}" ToolTip="设置" Margin="5,0"
                        Command="{Binding OpenSettingsCommand}">
                    <materialDesign:PackIcon Kind="Settings" Width="24" Height="24" Foreground="{DynamicResource MaterialDesignBody}"/>
                </Button>
                <Button Style="{DynamicResource MaterialDesignIconForegroundButton}" ToolTip="用户" Margin="5,0"
                        Command="{Binding OpenUserProfileCommand}">
                    <materialDesign:PackIcon Kind="Account" Width="24" Height="24" Foreground="{DynamicResource MaterialDesignBody}"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 主内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <!-- 左侧导航 -->
                <ColumnDefinition Width="*"/>
                <!-- 中间内容区 -->
                <ColumnDefinition Width="300"/>
                <!-- 右侧/扩展功能 -->
            </Grid.ColumnDefinitions>

            <!-- 左侧导航 -->
            <Grid Grid.Column="0" Background="{DynamicResource SideNavBackground}">
                <StackPanel Margin="10">
                    <!-- 媒体库导航 -->
                    <TextBlock Text="媒体库" Style="{DynamicResource SubtitleTextStyle}" Margin="10,20,10,5" Foreground="{DynamicResource MaterialDesignBody}"/>
                    <ListBox x:Name="NavigationListBox" Margin="0,5" 
                             Background="Transparent"
                             SelectedIndex="{Binding SelectedNavigationIndex}"
                             Foreground="{DynamicResource MaterialDesignBody}">
                        <ListBoxItem>
                            <ListBoxItem.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                                             Command="{Binding NavigateToAllMusicCommand}"/>
                            </ListBoxItem.InputBindings>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="MusicNote" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="所有音乐" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <ListBoxItem.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                                             Command="{Binding NavigateToArtistsCommand}"/>
                            </ListBoxItem.InputBindings>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Microphone" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="艺术家" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <ListBoxItem.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                                             Command="{Binding NavigateToAlbumsCommand}"/>
                            </ListBoxItem.InputBindings>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Album" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="专辑" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <ListBoxItem.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                                             Command="{Binding NavigateToFavoriteAlbumsCommand}"/>
                            </ListBoxItem.InputBindings>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Album" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="收藏专辑" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>

                    <!-- 播放列表 -->
                    <Grid Margin="0,20,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="播放列表" Style="{DynamicResource SubtitleTextStyle}" Margin="10,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                        <Button Grid.Column="1" Style="{DynamicResource MaterialDesignIconButton}" 
                                Width="22" Height="22" Padding="0" Margin="0,0,5,0"
                                Command="{Binding CreatePlaylistCommand}">
                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"/>
                        </Button>
                    </Grid>

                    <ListBox x:Name="PlaylistsListBox" Margin="0,5" 
                             Background="Transparent"
                             ItemsSource="{Binding Playlists}"
                             SelectedItem="{Binding SelectedPlaylist}"
                             Foreground="{DynamicResource MaterialDesignBody}"
                             PreviewMouseDown="PlaylistsListBox_PreviewMouseDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" Margin="5" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 导入音乐按钮 -->
                    <Button Margin="10,20,10,10" HorizontalAlignment="Stretch"
                            Style="{DynamicResource MaterialDesignOutlinedButton}"
                            Command="{Binding ImportMusicCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="MusicNote" Width="20" Height="20"/>
                            <TextBlock Text="导入音乐" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- 修复数据库按钮 -->
                    <Button Margin="10,5,10,10" HorizontalAlignment="Stretch"
                            Style="{DynamicResource MaterialDesignOutlinedButton}"
                            Command="{Binding FixDatabaseCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseRefresh" Width="20" Height="20"/>
                            <TextBlock Text="修复数据库" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 中间内容区 - 使用内容控件实现视图切换 -->
            <ContentControl Grid.Column="1" 
                          x:Name="MainContentControl" 
                          Content="{Binding CurrentView}" 
                          Background="{DynamicResource ContentBackground}">
                <ContentControl.Resources>
                    <DataTemplate x:Key="FavoritesView">
                        <UserControls:FavoritesUserControl />
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>

            <!-- 右侧/扩展功能 -->
            <Grid Grid.Column="2" Background="{DynamicResource SideNavBackground}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 当前播放信息 -->
                <StackPanel Grid.Row="0" Margin="15" Visibility="{Binding IsPlaying, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="正在播放" Style="{DynamicResource SubtitleTextStyle}" Foreground="{DynamicResource MaterialDesignBody}"/>
                    <Border Width="120" Height="120" Margin="0,10" HorizontalAlignment="Center" CornerRadius="5" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Image Source="{Binding CurrentSong.AlbumArt}" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Text="{Binding CurrentSong.Title}" FontWeight="Bold" FontSize="14" TextAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource MaterialDesignBody}"/>
                    <TextBlock Text="{Binding CurrentSong.Artist.Name}" Opacity="0.7" TextAlignment="Center" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource MaterialDesignBody}"/>
                </StackPanel>

                <!-- 歌词/扩展功能 -->
                <Grid Grid.Row="1" Margin="15">
                    <!-- 使用自定义歌词控件 -->
                    <controls:LyricControl Visibility="{Binding IsPlaying, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    
                    <!-- 未播放时的提示 -->
                    <TextBlock Text="播放音乐可查看歌词" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               Opacity="0.5" 
                               Visibility="{Binding IsPlaying, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- 播放控制栏 -->
        <Grid Grid.Row="2" Background="{DynamicResource PlayBarBackground}" Height="85">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <!-- 歌曲信息 -->
                <ColumnDefinition Width="*"/>
                <!-- 播放控制 -->
                <ColumnDefinition Width="200"/>
                <!-- 音量控制 -->
            </Grid.ColumnDefinitions>

            <!-- 歌曲信息 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="15" Visibility="{Binding IsPlaying, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Width="55" Height="55" CornerRadius="3" BorderThickness="1" BorderBrush="#333">
                    <Image Source="{Binding CurrentSong.AlbumArt}" Stretch="UniformToFill"/>
                </Border>
                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center" Width="200">
                    <TextBlock Text="{Binding CurrentSong.Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding CurrentSong.Artist.Name}" Opacity="0.7" FontSize="12" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding CurrentSong.Album.Songs.Count, Converter={StaticResource SongCountConverter}}" Opacity="0.7" FontSize="12" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </StackPanel>

            <!-- 播放控制 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <!-- 随机播放按钮 (移动到左侧) -->
                    <Button Style="{DynamicResource MaterialDesignIconButton}"
                          Height="32" Width="32" Padding="0" Margin="5,0"
                          Command="{Binding ToggleShuffleCommand}"
                          Background="{Binding IsShuffleEnabled, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#9C27B0'}">
                        <materialDesign:PackIcon Kind="Shuffle" Width="18" Height="18"/>
                    </Button>

                    <!-- 上一曲按钮 -->
                    <Button Style="{DynamicResource MaterialDesignIconButton}" 
                            Height="40" Width="40" Padding="0" Margin="15,0"
                            Command="{Binding PreviousTrackCommand}">
                        <materialDesign:PackIcon Kind="SkipPrevious" Width="30" Height="30"/>
                    </Button>

                    <!-- 播放/暂停按钮 -->
                    <Button Style="{DynamicResource MaterialDesignFloatingActionButton}" 
                            Height="48" Width="48" Padding="0"
                            Background="{DynamicResource PrimaryHueMidBrush}"
                            Command="{Binding PlayPauseCommand}">
                        <materialDesign:PackIcon Kind="{Binding PlayPauseIcon}" Width="26" Height="26"/>
                    </Button>

                    <!-- 下一曲按钮 -->
                    <Button Style="{DynamicResource MaterialDesignIconButton}" 
                            Height="40" Width="40" Padding="0" Margin="15,0"
                            Command="{Binding NextTrackCommand}">
                        <materialDesign:PackIcon Kind="SkipNext" Width="30" Height="30"/>
                    </Button>

                    <!-- 重复播放按钮 -->
                    <Button Style="{DynamicResource MaterialDesignIconButton}"
                          Height="32" Width="32" Padding="0" Margin="5,0"
                          Command="{Binding ToggleRepeatCommand}"
                          ToolTip="{Binding RepeatModeToolTip}">
                        <materialDesign:PackIcon Kind="{Binding RepeatModeIcon}" Width="18" Height="18"/>
                    </Button>
                </StackPanel>

                <!-- 进度条 -->
                <Grid Width="500">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding CurrentPositionText}" FontSize="10" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                    <Slider Grid.Column="1" Minimum="0" Maximum="{Binding TotalSeconds}" 
                            Value="{Binding CurrentPositionSeconds, Mode=TwoWay}" 
                            Style="{DynamicResource MaterialDesignSlider}"
                            TickPlacement="None"
                            SmallChange="1"
                            LargeChange="5"
                            IsSnapToTickEnabled="True"
                            IsMoveToPointEnabled="True"/>

                    <TextBlock Grid.Column="2" Text="{Binding TotalTimeText}" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- 音量控制 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                <ToggleButton Style="{DynamicResource MaterialDesignIconToggleButton}"
                              Height="30" Width="30" Padding="0"
                              IsChecked="{Binding IsMuted}"
                              Command="{Binding ToggleMuteCommand}">
                    <materialDesign:PackIcon Kind="VolumeHigh" Width="18" Height="18"/>
                </ToggleButton>

                <Slider Width="120" Margin="10,0,10,0" Minimum="0" Maximum="100" 
                        Value="{Binding Volume}" 
                        Style="{DynamicResource MaterialDesignSlider}"
                        TickPlacement="None"
                        IsMoveToPointEnabled="True"/>
                
                <!-- 均衡器按钮 -->
                <Button Style="{DynamicResource MaterialDesignIconButton}"
                        Height="30" Width="30" Padding="0"
                        Command="{Binding OpenEqualizerCommand}">
                    <materialDesign:PackIcon Kind="Equalizer" Width="18" Height="18"/>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>