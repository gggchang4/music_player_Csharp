<UserControl x:Class="MusicPlayerApp.Views.ArtistDetailsUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:MusicPlayerApp.Views"
             xmlns:converters="clr-namespace:MusicPlayerApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,10,20,0">
            <Button 
                Command="{Binding BackCommand}" 
                Style="{DynamicResource MaterialDesignFlatButton}" 
                ToolTip="返回" 
                Margin="0,0,10,0">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24"/>
            </Button>
            <TextBlock Text="艺术家详情" FontSize="20" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 艺术家信息 -->
        <Grid Grid.Row="1" Margin="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 艺术家头像 -->
            <Border Grid.Column="0" 
                    Width="100" Height="100" 
                    Background="{DynamicResource PrimaryHueLightBrush}" 
                    CornerRadius="50">
                <materialDesign:PackIcon Kind="Microphone" 
                                       Width="60" Height="60" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
            </Border>

            <!-- 艺术家名称和简介 -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Artist.Name}" 
                         FontSize="24" 
                         FontWeight="Bold"
                         TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Artist.Biography, FallbackValue=暂无简介}" 
                         Opacity="0.7"
                         TextWrapping="Wrap"
                         Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 热门歌曲 -->
        <StackPanel Grid.Row="2" Margin="20,20,20,10">
            <TextBlock Text="热门歌曲" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
            
            <!-- 加载指示器 -->
            <ProgressBar IsIndeterminate="True"
                       Margin="0,20,0,0"
                       HorizontalAlignment="Center"
                       Width="60" Height="60"
                       Style="{DynamicResource MaterialDesignCircularProgressBar}"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
            
            <ListView ItemsSource="{Binding PopularSongs}" 
                    BorderThickness="0"
                    Style="{DynamicResource MaterialDesignListView}"
                    MaxHeight="300"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Album.Title}" FontSize="12" Opacity="0.7"/>
                                    <TextBlock Text=" • " FontSize="12" Opacity="0.7"/>
                                    <TextBlock Text="{Binding Duration, Converter={StaticResource TimeSpanToStringConverter}}" FontSize="12" Opacity="0.7"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- 收藏按钮 -->
                            <Button Grid.Column="1" 
                                  Style="{DynamicResource MaterialDesignFlatButton}"
                                  Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}">
                                <materialDesign:PackIcon Kind="Heart" Width="24" Height="24"/>
                            </Button>

                            <!-- 添加到播放列表按钮 -->
                            <Button Grid.Column="2" 
                                  Style="{DynamicResource MaterialDesignFlatButton}"
                                  Command="{Binding DataContext.AddToPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}">
                                <materialDesign:PackIcon Kind="PlaylistPlus" Width="24" Height="24"/>
                            </Button>

                            <!-- 播放按钮 -->
                            <Button Grid.Column="3" 
                                  Style="{DynamicResource MaterialDesignFlatButton}"
                                  Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}">
                                <materialDesign:PackIcon Kind="Play" Width="24" Height="24"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            
            <!-- 无歌曲提示 -->
            <TextBlock Text="暂无热门歌曲" 
                     FontSize="16" 
                     HorizontalAlignment="Center" 
                     Margin="0,20,0,0"
                     Visibility="{Binding PopularSongs.Count, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Zero}"/>
        </StackPanel>

        <!-- 专辑 -->
        <StackPanel Grid.Row="3" Margin="20,20,20,20">
            <TextBlock Text="专辑" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
            
            <ItemsControl ItemsSource="{Binding Albums}" 
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10,10,10,20" Width="160">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="160"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 专辑封面 -->
                            <Border Grid.Row="0" 
                                  Background="{DynamicResource PrimaryHueLightBrush}" 
                                  CornerRadius="3">
                                <Grid>
                                    <!-- 专辑封面图片 -->
                                    <Image Source="{Binding CoverImage}"
                                           Stretch="UniformToFill"
                                           Visibility="{Binding CoverImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    
                                    <!-- 当没有图片时显示默认图标 -->
                                    <materialDesign:PackIcon Kind="Album" 
                                                           Width="80" Height="80" 
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding CoverImage, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                </Grid>
                            </Border>
                            
                            <!-- 专辑标题 -->
                            <TextBlock Grid.Row="1" 
                                     Text="{Binding Title}" 
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap"
                                     Margin="0,10,0,0"
                                     HorizontalAlignment="Center"/>
                            
                            <!-- 浏览按钮 -->
                            <Button Grid.Row="2" 
                                  Content="浏览"
                                  Style="{DynamicResource MaterialDesignFlatButton}"
                                  Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}"
                                  HorizontalAlignment="Center"
                                  Margin="0,5,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <!-- 无专辑提示 -->
            <TextBlock Text="暂无专辑" 
                     FontSize="16" 
                     HorizontalAlignment="Center" 
                     Margin="0,20,0,0"
                     Visibility="{Binding Albums.Count, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Zero}"/>
        </StackPanel>
    </Grid>
</UserControl> 