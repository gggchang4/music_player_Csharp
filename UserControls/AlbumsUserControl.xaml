<UserControl x:Class="MusicPlayerApp.UserControls.AlbumsUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicPlayerApp.UserControls"
             xmlns:converters="clr-namespace:MusicPlayerApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <TextBlock Text="专辑" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Margin="20,20,0,10"/>
        
        <!-- 内容区域 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Albums}" Margin="20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="180" Height="220" Margin="10" Background="#2A2A2A" CornerRadius="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="160"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 专辑封面 -->
                                <Image Grid.Row="0" Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                
                                <!-- 专辑标题 -->
                                <TextBlock Grid.Row="1" 
                                           Text="{Binding Title}" 
                                           Margin="10,5,10,0" 
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="SemiBold"/>
                                
                                <!-- 艺术家 -->
                                <TextBlock Grid.Row="2" 
                                           Text="{Binding Artist.Name}" 
                                           Margin="10,0,10,10"
                                           Opacity="0.7"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="12"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl> 